<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f8;font-family:Segoe UI,Tahoma,Geneva,Verdana,sans-serif;color:#1a1a1a;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f4f6f8;padding:24px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="max-width:600px;background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
          <tr>
            <td style="background:linear-gradient(135deg,#0d47a1,#1565c0);padding:20px 28px;color:#ffffff;">
              <div style="font-size:20px;font-weight:600;letter-spacing:0.5px;">TM</div>
              {{#if status}}
              <div style="margin-top:8px;font-size:13px;opacity:0.95;">{{status}}</div>
              {{/if}}
            </td>
          </tr>
          <tr>
            <td style="padding:28px 28px 8px;">
              <h1 style="margin:0 0 8px;font-size:22px;font-weight:600;color:#0d47a1;">{{title}}</h1>
              <p style="margin:0 0 16px;font-size:15px;color:#424242;">Hola {{name}},</p>
            </td>
          </tr>
          <tr>
            <td style="padding:0 28px 24px;font-size:15px;line-height:1.55;color:#333333;">
              {{{messageHtml}}}
            </td>
          </tr>
          {{#if buttonLink}}
          <tr>
            <td style="padding:0 28px 28px;" align="center">
              <a href="{{buttonLink}}" style="display:inline-block;padding:12px 28px;background:#1565c0;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:14px;">{{buttonText}}</a>
            </td>
          </tr>
          {{/if}}
          <tr>
            <td style="padding:20px 28px;background:#eceff1;font-size:12px;line-height:1.5;color:#546e7a;">
              {{{footerHtml}}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
