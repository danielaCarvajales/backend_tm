<!DOCTYPE html>
<html lang="{{htmlLang}}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
</head>
<body style="{{styles.body}}">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="{{styles.outerTable}}">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="{{styles.card}}">
          <tr>
            <td style="{{styles.headerCell}}">
              <table role="presentation" cellspacing="0" cellpadding="0" style="{{styles.brandRow}}">
                <tr>
                  {{#if logoUrl}}
                  <td style="{{styles.brandLogoCell}}">
                    <img src="{{logoUrl}}" alt="{{brandAlt}}" width="30" height="30" style="{{styles.brandLogo}}" />
                  </td>
                  {{/if}}
                  <td style="{{styles.brandTitleCell}}">
                    <div style="{{styles.brandTitle}}">TM</div>
                  </td>
                </tr>
              </table>
              {{#if status}}
              <div style="{{styles.statusLine}}">{{status}}</div>
              {{/if}}
            </td>
          </tr>
          <tr>
            <td style="{{styles.titleRow}}">
              <h1 style="{{styles.titleHeading}}">{{title}}</h1>
              <p style="{{styles.greeting}}">{{greetingPrefix}} {{name}},</p>
            </td>
          </tr>
          <tr>
            <td style="{{styles.messageCell}}">
              {{{messageHtml}}}
            </td>
          </tr>
          {{#if buttonLink}}
          <tr>
            <td style="{{styles.buttonCell}}" align="center">
              <a href="{{buttonLink}}" style="{{styles.buttonLink}}">{{buttonText}}</a>
            </td>
          </tr>
          {{/if}}
          <tr>
            <td align="center" style="{{styles.footerCell}}">
              {{{footerHtml}}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
