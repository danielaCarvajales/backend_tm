<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;">
  <tr>
    <td align="center" style="{{styles.inner}}">
      <p style="{{styles.companyName}}">{{companyName}}</p>
      <p style="{{styles.contactLine}}">
        {{address}}&nbsp;-&nbsp;<a href="mailto:{{email}}" style="{{styles.emailLink}}">{{email}}</a>&nbsp;-&nbsp;{{phone}}
      </p>
      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;">
        <tr>
          <td align="center" style="{{styles.iconsOuter}}">
            <table role="presentation" cellspacing="0" cellpadding="0" align="center" style="{{styles.iconsRow}}">
              <tr>
                <td style="{{styles.iconCell}}">
                  <a href="{{linkInstitution}}" target="_blank" rel="noopener noreferrer" style="{{styles.iconLink}}"
                    title="Institución">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                      stroke="#242454" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
                      aria-hidden="true">
                      <path d="M3 21h18" />
                      <path d="M5 21V7l7-4 7 4v14" />
                      <path d="M9 21v-4h6v4" />
                      <path d="M9 10h6" />
                    </svg>
                  </a>
                </td>
                <td style="{{styles.iconCell}}">
                  <a href="{{linkWeb}}" target="_blank" rel="noopener noreferrer" style="{{styles.iconLink}}"
                    title="Web">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                      stroke="#242454" stroke-width="1.6" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" />
                      <path d="M2 12h20" />
                      <path
                        d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                  </a>
                </td>
                <td style="{{styles.iconCell}}">
                  <a href="{{linkPortal}}" target="_blank" rel="noopener noreferrer" style="{{styles.iconLink}}"
                    title="Portal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#242454"
                      aria-hidden="true">
                      <path
                        d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 1.5c1.21 0 2.32.38 3.25 1.02-.65 1.47-1.48 2.73-2.42 3.65-.55-.36-1.14-.67-1.83-.67-.69 0-1.28.31-1.83.67-.94-.92-1.77-2.18-2.42-3.65.93-.64 2.04-1.02 3.25-1.02zM8.5 6.2c.58 1.2 1.28 2.28 2.05 3.13-.95.76-1.55 1.92-1.55 3.17H4.7a8.46 8.46 0 0 1 3.8-6.3zm7 0a8.46 8.46 0 0 1 3.8 6.3h-4.3c0-1.25-.6-2.41-1.55-3.17.77-.85 1.47-1.93 2.05-3.13zM12 13.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zm-5.3 1h10.6c-.58 1.2-1.28 2.28-2.05 3.13.95.76 1.55 1.92 1.55 3.17H8.7c0-1.25.6-2.41 1.55-3.17-.77-.85-1.47-1.93-2.05-3.13zm-2.5 4.3a8.46 8.46 0 0 1-3.8-6.3h4.3c0 1.25.6 2.41 1.55 3.17-.77.85-1.47 1.93-2.05 3.13a8.46 8.46 0 0 1-3.8 6.3zm12.6 0a8.46 8.46 0 0 1-3.8-6.3c.58-1.2 1.28-2.28 2.05-3.13.95-.76 1.55-1.92 1.55-3.17h4.3a8.46 8.46 0 0 1-3.8 6.3z" />
                    </svg>
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
      <div style="{{styles.divider}}"></div>
      <p style="{{styles.legalCopy}}">© {{copyrightYear}} {{companyName}}. TODOS LOS DERECHOS RESERVADOS.</p>
    </td>
  </tr>
</table>
