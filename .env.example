# ===========================================
# Backend TM - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Server
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=backend_tm

# JWT Authentication (REQUIRED for auth module)
# Security: Minimum 64 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_64_characters_long_for_security_purposes

# Redis (REQUIRED for OTP send-otp: storage + rate limits).
# Si no tienes Redis instalado: docker run -d --name redis-tm -p 6379:6379 redis:alpine
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# OTP (POST /api/auth/send-otp) — secret used to HMAC OTP before storing in Redis (min 32 chars)
OTP_SECRET=change_me_use_at_least_32_random_characters_hex_or_base64
# TTL for OTP hash in Redis (seconds). Default 600 (10 minutes).
OTP_TTL_SECONDS=300
OTP_RL_EMAIL_MAX=3
OTP_RL_EMAIL_WINDOW_SEC=300
# Per-IP: max requests per minute (default 10 per 60s)
OTP_RL_IP_MAX=5
OTP_RL_IP_WINDOW_SEC=60

# Optional: OTP email copy (see SendOtpEmailService)
# EMAIL_SUBJECT_OTP=Your verification code
# EMAIL_HEADING_OTP=Verification code

# DigitalOcean Spaces (S3-compatible; usado por upload de documentos y URL del logo en correos)
# DO_SPACES_ENDPOINT=https://atl1.digitaloceanspaces.com
# DO_SPACES_REGION=atl1
# DO_SPACES_BUCKET=your-bucket
# DO_SPACES_ACCESS_KEY_ID=
# DO_SPACES_SECRET_ACCESS_KEY=
# URL pública del bucket o CDN (sin barra final). Misma base que usa SpacesFileStorageService.
# DO_SPACES_PUBLIC_BASE_URL=https://your-bucket.atl1.cdn.digitaloceanspaces.com

# Email footer (shared by all templates)
# Logo: sube el PNG al bucket bajo la carpeta assets/, p. ej. assets/logotm.png (lectura pública).
# La URL del <img> se arma como DO_SPACES_PUBLIC_BASE_URL + EMAIL_LOGO_SPACES_KEY (por defecto assets/logotm.png).
# Si necesitas otra URL exacta, usa EMAIL_LOGO_URL (tiene prioridad sobre Spaces).
# EMAIL_LOGO_URL=
# EMAIL_LOGO_SPACES_KEY=assets/logotm.png
# EMAIL_FOOTER_COMPANY_NAME=...
# EMAIL_FOOTER_COPYRIGHT_YEAR=2026
# EMAIL_FOOTER_ADDRESS=...
# EMAIL_FOOTER_EMAIL=...
# EMAIL_FOOTER_PHONE=...
# EMAIL_FOOTER_LINK_INSTITUTION=...
# EMAIL_FOOTER_LINK_WEB=...
# EMAIL_FOOTER_LINK_PORTAL=...

# Correo de bienvenida (tras POST /api/credentials — SendWelcomeEmailUseCase + layout/welcome-body.hbs)
# EMAIL_SUBJECT_WELCOME=Bienvenido a TM
# EMAIL_HEADING_WELCOME=Bienvenido
# EMAIL_WELCOME_DASHBOARD_URL=https://tu-app.com/login

# Correo al crear caso (CreateCaseRecordUseCase — plantilla case-created-body.hbs + layout)
# EMAIL_SUBJECT_CASE_CREATED=Caso TM-123 creado
# EMAIL_HEADING_CASE_CREATED=Nuevo caso registrado
# URL base del front para el botón "Ver caso" (se añade /{idCase})
# EMAIL_CASE_DETAIL_BASE_URL=https://tu-app.com/case-records
